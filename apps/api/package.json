{
  "name": "@ecac/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run --passWithNoTests",
    "prisma:generate": "dotenv -e ../../.env -- prisma generate --schema src/prisma/schema.prisma",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev --schema src/prisma/schema.prisma",
    "db:seed": "dotenv -e ../../.env -- tsx src/prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.5",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.5",
    "@nestjs/platform-express": "^10.4.5",
    "@nestjs/mapped-types": "^2.1.0",
    "@prisma/client": "^5.19.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "bullmq": "^5.13.2",
    "ioredis": "^5.4.1",
    "pino": "^9.3.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@types/express": "^5.0.0",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "dotenv-cli": "^11.0.0",
    "prisma": "^5.19.1",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
}
